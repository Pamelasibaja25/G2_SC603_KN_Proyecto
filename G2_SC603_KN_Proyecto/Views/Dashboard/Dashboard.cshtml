</div>

<!-- Gráficos -->
<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h6 class="mb-0">Ingresos Mensuales</h6>
                <select class="form-select form-select-sm" style="width: auto;">
                    <option>2026</option>
                    <option>2025</option>
                </select>
            </div>
            <div class="card-body">
                <canvas id="chartIngresos"></canvas>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card">
            <div class="card-header">
                <h6 class="mb-0">Tipos de Membresía</h6>
            </div>
            <div class="card-body">
                <canvas id="chartMembresias"></canvas>
                <div class="mt-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bx bx-radio-circle" style="color: #696cff;"></i> Premium</span>
                        <span>8 clientes</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span><i class="bx bx-radio-circle" style="color: #00cec9;"></i> Estándar</span>
                        <span>10 clientes</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span><i class="bx bx-radio-circle" style="color: #fee140;"></i> Trial</span>
                        <span>6 clientes</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

