<!-- Scripts para gráficos (usando Chart.js como ejemplo) -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // Gráfico de Ingresos Mensuales
    var ctxIngresos = document.getElementById('chartIngresos').getContext('2d');
    var chartIngresos = new Chart(ctxIngresos, {
        type: 'line',
        data: {
            labels: ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'],
            datasets: [{
                label: 'Ingresos (₡)',
                data: [320000, 350000, 380000, 420000, 390000, 450000, 480000, 460000, 500000, 520000, 510000, 550000],
                borderColor: '#696cff',
                backgroundColor: 'rgba(105, 108, 255, 0.1)',
                tension: 0.4,
                fill: true,
                pointRadius: 4,
                pointBackgroundColor: '#696cff'
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: true,
                    position: 'top'
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        callback: function (value) {
                            return '₡' + value.toLocaleString();
                        }
                    }
                }
            }
        }
    });

    // Gráfico de Tipos de Membresía (Pie)
    var ctxMembresias = document.getElementById('chartMembresias').getContext('2d');
    var chartMembresias = new Chart(ctxMembresias, {
        type: 'doughnut',
        data: {
            labels: ['Premium', 'Estándar', 'Trial'],
            datasets: [{
                data: [8, 10, 6],
                backgroundColor: ['#696cff', '#00cec9', '#fee140'],
                borderColor: '#fff',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                }
            }
        }
    });
</script>
