@{
    Layout = "_Layout";
}
<div id="page-dashboard" class="section-page active p-6 lg:p-8 space-y-8">
    <div>
        <h2 class="font-headline text-3xl font-bold tracking-tight">Overview</h2>
        <p class="text-on-surface-variant text-xs uppercase tracking-[0.15em] mt-1">Métricas en vivo del estudio</p>
    </div>

    <!-- Metric Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="metric-card bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Clientes Activos</span>
                <span class="material-symbols-outlined text-primary-container text-[20px]" style="font-variation-settings:'wght' 300">group</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-on-surface" id="metricClients">147</div>
            <div class="mt-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-tertiary-fixed text-[14px]" style="font-variation-settings:'wght' 300">trending_up</span>
                <span class="text-tertiary-fixed text-xs font-semibold">+8 esta semana</span>
            </div>
        </div>
        <div class="metric-card wine bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Ingresos del Mes</span>
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-[20px]" style="font-variation-settings:'wght' 300">monetization_on</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-on-surface">₡486K</div>
            <div class="mt-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-tertiary-fixed text-[14px]" style="font-variation-settings:'wght' 300">trending_up</span>
                <span class="text-tertiary-fixed text-xs font-semibold">+12% vs mes anterior</span>
            </div>
        </div>
        <div class="metric-card bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Asistencia Diaria</span>
                <span class="material-symbols-outlined text-secondary text-[20px]" style="font-variation-settings:'wght' 300">directions_run</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-on-surface">34</div>
            <div class="mt-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-tertiary-fixed text-[14px]">show_chart</span>
                <span class="text-on-surface-variant text-xs">Promedio diario</span>
            </div>
        </div>
        <div class="metric-card bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Vencen en 7 días</span>
                <span class="material-symbols-outlined text-[#fbbf24] text-[20px]" style="font-variation-settings:'wght' 300">warning</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-[#fbbf24]">12</div>
            <div class="mt-2 flex items-center gap-1">
                <span class="material-symbols-outlined text-[#fbbf24] text-[14px]">schedule</span>
                <span class="text-[#fbbf24] text-xs font-semibold">Requieren renovación</span>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Attendance Chart -->
        <div class="lg:col-span-2 bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="font-headline font-bold text-lg">Asistencia Semanal</h3>
                    <p class="text-on-surface-variant text-xs">Últimos 7 días</p>
                </div>
                <div class="flex gap-1">
                    <button class="tab-btn active" onclick="this.parentNode.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active')">Semana</button>
                    <button class="tab-btn" onclick="this.parentNode.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));this.classList.add('active')">Mes</button>
                </div>
            </div>
            <div class="flex items-end justify-between gap-2 h-40" id="attendanceChart">
                <!-- Bars rendered by JS -->
            </div>
            <div class="flex justify-between mt-2 text-[10px] text-outline uppercase tracking-wider" id="chartLabels"></div>
        </div>

        <!-- Expiring Soon -->
        <div class="bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex items-center justify-between mb-5">
                <h3 class="font-headline font-bold text-base">Alertas de Vencimiento</h3>
                <span class="material-symbols-outlined text-[#fbbf24] text-[20px]">warning_amber</span>
            </div>
            <div class="space-y-3" id="expiringList">
                <!-- rendered by JS -->
            </div>
        </div>
    </div>

    <!-- Ranking + Daily Income -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <h3 class="font-headline font-bold text-base mb-5">Top Clientes — Asistencia</h3>
            <div class="space-y-3" id="rankingList"></div>
        </div>
        <div class="bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex items-center justify-between mb-5">
                <h3 class="font-headline font-bold text-base">Ingresos de Hoy</h3>
                <span class="text-on-surface-variant text-xs" id="todayDate"></span>
            </div>
            <div class="text-center py-4">
                <div class="font-headline text-5xl font-black tracking-tighter text-primary-container" id="todayIncome">₡38,500</div>
                <p class="text-on-surface-variant text-xs mt-2">Total cobrado hoy</p>
            </div>
            <div class="mt-4 space-y-2" id="todayPaymentsList"></div>
        </div>
    </div>
</div>
