                            <i class="bx bx-up-arrow-alt"></i> +15% vs mes anterior
                        </small>
                    </div>
                    <div class="avatar bg-light-success p-2">
                        <i class="bx bx-wallet text-success" style="font-size: 1.5rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="text-muted mb-1">Asistencia Hoy</h6>
                        <h3 class="mb-0">16</h3>
                        <small class="text-info">
                            <i class="bx bx-check-circle"></i> Check-ins registrados
