@model G2_SC603_KN_Proyecto.Models.DashboardViewModel
@{
    Layout = "_Layout";
}
<div id="page-dashboard" class="section-page active p-6 lg:p-8 space-y-8">
    <div>
        <h2 class="font-headline text-3xl font-bold tracking-tight">Overview</h2>
        <p class="text-on-surface-variant text-xs uppercase tracking-[0.15em] mt-1">Métricas en vivo del estudio</p>
    </div>

    @if (Model.AlertasStock != null && Model.AlertasStock.Any())
    {
        <div class="bg-amber-600/20 border border-amber-500 rounded-2xl p-4">
            <div class="flex items-center gap-2 mb-3">
                <span class="material-symbols-outlined text-amber-400 text-[22px]">warning</span>
                <h3 class="font-headline font-bold text-sm text-amber-300">
                    Stock bajo en @Model.AlertasStock.Count producto(s)
                </h3>
            </div>
            <div class="flex flex-wrap gap-3">
                @foreach (var alerta in Model.AlertasStock)
                {
                    <div class="bg-amber-600/30 rounded-xl px-3 py-2 text-xs">
                        <span class="font-semibold">@alerta.Producto</span>
                        — Cantidad: <span class="text-amber-300 font-bold">@alerta.CantidadActual</span>
                        (mínimo: @alerta.StockMinimo)
                    </div>
                }
            </div>
        </div>
    }

    <!-- Metric Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="metric-card bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Clientes Activos</span>
                <span class="material-symbols-outlined text-primary-container text-[20px]" style="font-variation-settings:'wght' 300">group</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-on-surface">@Model.ClientesActivos</div>
        </div>
        <div class="metric-card wine bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Ingresos del Mes</span>
                <span class="material-symbols-outlined text-tertiary-fixed-dim text-[20px]" style="font-variation-settings:'wght' 300">monetization_on</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-on-surface">₡@Model.IngresosMes.ToString("N0")</div>
        </div>
        <div class="metric-card bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Asistencia Diaria</span>
                <span class="material-symbols-outlined text-secondary text-[20px]" style="font-variation-settings:'wght' 300">directions_run</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-on-surface">@Model.AsistenciaHoy</div>
        </div>
        <div class="metric-card bg-surface-container rounded-2xl p-5 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex justify-between items-start mb-3">
                <span class="text-on-surface-variant text-[10px] uppercase tracking-wider font-bold">Vencen en 7 días</span>
                <span class="material-symbols-outlined text-[#fbbf24] text-[20px]" style="font-variation-settings:'wght' 300">warning</span>
            </div>
            <div class="font-headline text-4xl font-black tracking-tighter text-[#fbbf24]">@Model.MembresiasPorVencer</div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Gráfico de asistencia -->
        <div class="lg:col-span-2 bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex items-center justify-between mb-6">
                <div>
                    <h3 class="font-headline font-bold text-lg">Asistencia</h3>
                    <p class="text-on-surface-variant text-xs">Ingresos al gimnasio por dia &middot; semana, mes o rango de fechas</p>
                </div>
                <div class="flex gap-1">
                    <button id="btnSemana" class="tab-btn active" onclick="cambiarPeriodo('semana')">Semana</button>
                    <button id="btnMes" class="tab-btn" onclick="cambiarPeriodo('mes')">Mes</button>
                    <button id="btnRango" class="tab-btn" onclick="cambiarPeriodo('rango')">Rango</button>
                </div>
            </div>

            <form method="get" asp-controller="Dashboard" asp-action="Dashboard" class="flex flex-wrap items-center gap-2 mb-4">
                <input type="date" name="fechaInicio" class="input-field text-xs py-1.5" style="max-width:160px"
                       value="@(Model.FechaInicio?.ToString("yyyy-MM-dd"))" required />
                <input type="date" name="fechaFin" class="input-field text-xs py-1.5" style="max-width:160px"
                       value="@(Model.FechaFin?.ToString("yyyy-MM-dd"))" required />
                <button type="submit" class="tab-btn">Aplicar</button>
            </form>

            @if (Model.RangoInvalido)
            {
                <p class="text-xs mb-3" style="color:#ffb4ab;">El rango de fechas no es válido.</p>
            }

            <div style="height:300px"><canvas id="attendanceChart"></canvas></div>
            <p id="chartEmptyMsg" class="text-on-surface-variant text-xs text-center mt-2" style="display:none;">
                No hay asistencias registradas para el período seleccionado.
            </p>
        </div>

        <div class="bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex items-center justify-between mb-5">
                <h3 class="font-headline font-bold text-base">Alertas de Vencimiento</h3>
                <span class="material-symbols-outlined text-[#fbbf24] text-[20px]">warning_amber</span>
            </div>
            @if (Model.Vencimientos != null && Model.Vencimientos.Any())
            {
                @foreach (var item in Model.Vencimientos)
                {
                    <a asp-controller="Clientes" asp-action="MostrarClientes"
                       class="block border-b pb-3 mb-3 hover:opacity-80 cursor-pointer">
                        <strong>@item.Cliente</strong><br />
                        Vence: @item.FechaFin.ToString("dd/MM/yyyy")<br />
                        <small>@item.DiasRestantes días restantes</small>
                    </a>
                }
            }
            else
            {
                <p class="text-on-surface-variant text-sm">No hay alertas de vencimiento en los próximos 7 días.</p>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

        <div class="bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <h3 class="font-headline font-bold text-base mb-3">Top Clientes — Asistencia al Gimnasio</h3>

            <!-- AC3: filtro por período -->
            <form method="get" asp-controller="Dashboard" asp-action="Dashboard"
                  class="flex flex-wrap gap-2 items-end mb-4">
                <div>
                    <label class="label-float text-[10px]">Desde</label>
                    <input type="date" name="rankingInicio" class="input-field text-xs py-1.5" style="max-width:140px"
                           value="@(Model.RankingInicio?.ToString("yyyy-MM-dd"))" />
                </div>
                <div>
                    <label class="label-float text-[10px]">Hasta</label>
                    <input type="date" name="rankingFin" class="input-field text-xs py-1.5" style="max-width:140px"
                           value="@(Model.RankingFin?.ToString("yyyy-MM-dd"))" />
                </div>
                <button type="submit" class="tab-btn text-xs py-1.5">Filtrar</button>
                @if (Model.RankingInicio.HasValue || Model.RankingFin.HasValue)
                {
                    <a asp-controller="Dashboard" asp-action="Dashboard" class="tab-btn text-xs py-1.5">Limpiar</a>
                }
            </form>

            @if (Model.RankingClientes != null && Model.RankingClientes.Any())
            {
                <!-- AC1: ranking generado -->
                @foreach (var item in Model.RankingClientes)
                {
                    <div class="flex justify-between border-b py-2">
                        <span>@item.Cliente</span>
                        <span>@item.Asistencias asistencias</span>
                    </div>
                }
            }
            else
            {
                <!-- AC2: sin asistencias -->
                <p class="text-on-surface-variant text-sm">No hay datos de asistencia para el período seleccionado.</p>
            }
        </div>

        <div class="bg-surface-container rounded-2xl p-6 shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
            <div class="flex items-center justify-between mb-5">
                <h3 class="font-headline font-bold text-base">Ingresos de Hoy</h3>
                <span class="text-on-surface-variant text-xs" id="todayDate"></span>
            </div>
            <!-- AC1 y AC2: muestra ₡0 si no hay pagos, o el total si hay -->
            <div class="text-center py-4">
                <div class="font-headline text-5xl font-black tracking-tighter text-primary-container">
                    ₡@Model.IngresosHoy.ToString("N0")
                </div>
                <p class="text-on-surface-variant text-xs mt-2">
                    @if (Model.IngresosHoy == 0)
                    {
                        <span>No se han registrado pagos hoy</span>
                    }
                    else
                    {
                        <span>Total cobrado hoy</span>
                    }
                </p>
            </div>
            <!-- AC3: lista de pagos del día (se actualiza al recargar) -->
            <div class="mt-4 space-y-2">
                @foreach (var pago in Model.PagosHoy)
                {
                    <div class="flex justify-between border-b py-2">
                        <span>@pago.Cliente</span>
                        <span>₡@pago.Monto.ToString("N0")</span>
                        <span>@pago.Metodo</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    const asistenciaSemana = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AsistenciaSemanal));
    const asistenciaMes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AsistenciaMensual));
    const asistenciaRango = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AsistenciaRango));

    document.getElementById('todayDate').textContent = new Date().toLocaleDateString('es-CR', {
        weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    });
</script>
<script src="~/js/graficos.js" asp-append-version="true"></script>