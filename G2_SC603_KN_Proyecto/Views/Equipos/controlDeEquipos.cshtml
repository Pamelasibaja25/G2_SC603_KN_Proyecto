@{
    Layout = "_Layout";
}
<div id="page-inventory" class="section-page active p-6 lg:p-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h2 class="font-headline text-3xl font-bold tracking-tight">Inventario y Equipos</h2>
            <p class="text-on-surface-variant text-xs mt-1">RMGM-EQUIP-001 al RMGM-EQUIP-012</p>
        </div>
        <div class="flex gap-3 flex-wrap">
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
                <input type="text" id="invSearch" placeholder="Buscar equipo..." class="input-field pl-9 py-2.5 text-sm w-52" oninput="filterInventory()" />
            </div>
            <select class="input-field py-2.5 text-sm w-40" id="invStatusFilter" onchange="filterInventory()">
                <option value="">Todos</option>
                <option value="Activo">Activo</option>
                <option value="Mantenimiento">Mantenimiento</option>
                <option value="Inactivo">Inactivo</option>
            </select>
            <button class="btn-primary py-2.5 text-sm" onclick="openInventoryModal()">
                <span class="material-symbols-outlined text-[18px]">add</span> Nuevo Equipo
            </button>
        </div>
    </div>

    <!-- Low Stock Alert -->
    <div id="lowStockAlert" class="bg-[rgba(120,90,0,0.2)] border border-[rgba(251,191,36,0.25)] rounded-2xl p-4 mb-6 flex items-center gap-3">
        <span class="material-symbols-outlined text-[#fbbf24] text-[22px]">inventory</span>
        <p class="text-[#fbbf24] text-sm font-medium">⚠ Alertas de stock bajo — 2 productos requieren reposición</p>
    </div>

    <div class="bg-surface-container rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
        <div class="overflow-x-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Equipo / Producto</th>
                        <th>Categoría</th>
                        <th>Stock</th>
                        <th>Estado</th>
                        <th>Fecha Adquisición</th>
                        <th>Último Mantenimiento</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="inventoryTableBody"></tbody>
            </table>
        </div>
    </div>
</div>
<div class="modal-overlay" id="inventoryModal">
    <div class="modal-box">
        <div class="flex items-center justify-between mb-6">
            <h3 class="font-headline font-bold text-xl" id="inventoryModalTitle">Registrar Equipo</h3>
            <button onclick="closeModal('inventoryModal')" class="btn-icon"><span class="material-symbols-outlined">close</span></button>
        </div>
        <form id="inventoryForm" class="space-y-4">
            <input type="hidden" id="inventoryId" />
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="label-float">Nombre *</label>
                    <input type="text" id="invName" class="input-field" placeholder="Ej: Barra Olímpica 20kg" required />
                </div>
                <div>
                    <label class="label-float">Categoría *</label>
                    <select id="invCategory" class="input-field">
                        <option>Pesas y Barras</option>
                        <option>Cardio</option>
                        <option>Accesorios</option>
                        <option>Suplementos</option>
                        <option>Limpieza</option>
                        <option>Equipamiento</option>
                    </select>
                </div>
                <div>
                    <label class="label-float">Estado</label>
                    <select id="invStatus" class="input-field">
                        <option value="Activo">Activo</option>
                        <option value="Mantenimiento">En Mantenimiento</option>
                        <option value="Inactivo">Inactivo</option>
                    </select>
                </div>
                <div>
                    <label class="label-float">Cantidad *</label>
                    <input type="number" id="invQty" class="input-field" placeholder="0" min="0" required />
                </div>
                <div>
                    <label class="label-float">Stock Mínimo</label>
                    <input type="number" id="invMinStock" class="input-field" placeholder="0" min="0" />
                </div>
                <div>
                    <label class="label-float">Costo</label>
                    <input type="text" id="invCost" class="input-field" placeholder="₡0" />
                </div>
                <div>
                    <label class="label-float">Fecha de Adquisición</label>
                    <input type="date" id="invDate" class="input-field" />
                </div>
                <div class="col-span-2">
                    <label class="label-float">Descripción</label>
                    <textarea id="invDesc" class="input-field" rows="2" placeholder="Descripción del equipo o producto..."></textarea>
                </div>
            </div>
            <div class="flex gap-3 pt-2 justify-end">
                <button type="button" class="btn-secondary" onclick="closeModal('inventoryModal')">Cancelar</button>
                <button type="submit" class="btn-primary"><span class="material-symbols-outlined text-[16px]">save</span> Guardar</button>
            </div>
        </form>
    </div>
</div>