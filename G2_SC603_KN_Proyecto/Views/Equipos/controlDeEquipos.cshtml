@{
    ViewData["Mensaje"] = "Control de Equipos y Productos";
}

<div class="row">
    <div class="col-12">
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Inventario de Equipos</h5>
                <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#modalAgregarEquipo">
                    <i class="bx bx-plus"></i> Agregar Equipo
                </button>
            </div>
            <div class="card-body">
                <!-- Filtros -->
                <div class="row mb-4">
                    <div class="col-md-4">
                        <label class="form-label">Filtrar por Categoría</label>
                        <select class="form-select">
                            <option>Todas las categorías</option>
                            <option>Máquinas de Cardio</option>
                            <option>Pesas y Barras</option>
                            <option>Accesorios</option>
                            <option>Otros</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Estado</label>
                        <select class="form-select">
                            <option>Todos</option>
                            <option>Activo</option>
                            <option>En Mantenimiento</option>
                            <option>Inactivo</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Buscar Equipo</label>
                        <input type="text" class="form-control" placeholder="Nombre o código...">
                    </div>
                </div>

                <!-- Tabla de Equipos -->
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Equipo</th>
                                <th>Categoría</th>
                                <th>Cantidad</th>
                                <th>Estado</th>
                                <th>Último Mantenimiento</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
