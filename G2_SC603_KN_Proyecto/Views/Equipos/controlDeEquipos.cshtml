                                <td>10</td>
                                <td>
                                    <span class="badge bg-success">Activo</span>
                                </td>
                                <td>10/03/2026</td>
                                <td>
                                    <button class="btn btn-sm btn-info" title="Editar">
                                        <i class="bx bx-edit"></i>
                                    </button>
                                    <button class="btn btn-sm btn-warning" data-bs-toggle="modal" data-bs-target="#modalMantenimiento" title="Mantenimiento">
