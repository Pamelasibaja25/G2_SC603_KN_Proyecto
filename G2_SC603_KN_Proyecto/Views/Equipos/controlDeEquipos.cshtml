                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Mantenimientos Programados</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="mb-1">Caminadora TM-500</h6>
                                <small class="text-muted">Mantenimiento preventivo</small>
                            </div>
                            <span class="badge bg-info">12/04/2026</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="mb-1">Bicicleta Estática XR-300</h6>
                                <small class="text-muted">Revisión de componentes</small>
                            </div>
                            <span class="badge bg-warning">18/04/2026</span>
                        </div>
                    </div>
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between">
                            <div>
                                <h6 class="mb-1">Barras Olímpicas</h6>
                                <small class="text-muted">Reparación de daño</small>
                            </div>
                            <span class="badge bg-danger">En progreso</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">Control de Stock Crítico</h5>
            </div>
            <div class="card-body">
                <div class="list-group">
                    <div class="list-group-item border-start border-warning">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Botellas de Agua Reutilizables</h6>
                                <small class="text-muted">Stock actual: 3 unidades</small>
                            </div>
                            <span class="badge bg-warning">Crítico</span>
                        </div>
                    </div>
                    <div class="list-group-item border-start border-warning">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Toallas de Entrenamiento</h6>
                                <small class="text-muted">Stock actual: 5 unidades</small>
                            </div>
                            <span class="badge bg-warning">Bajo</span>
                        </div>
                    </div>
                    <div class="list-group-item border-start border-info">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0">Desinfectante para Equipos</h6>
                                <small class="text-muted">Stock actual: 8 unidades</small>
                            </div>
                            <span class="badge bg-info">Normal</span>
                        </div>
                    </div>
                </div>
                <button class="btn btn-sm btn-outline-primary mt-3 w-100">Registrar entrada de productos</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Agregar Equipo -->
<div class="modal fade" id="modalAgregarEquipo" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Agregar Nuevo Equipo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nombre del Equipo</label>
                        <input type="text" class="form-control" placeholder="ej: Caminadora TM-500">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Categoría</label>
                        <select class="form-select">
                            <option>Seleccione categoría</option>
                            <option>Máquinas de Cardio</option>
                            <option>Pesas y Barras</option>
                            <option>Accesorios</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cantidad</label>
                        <input type="number" class="form-control" placeholder="0" min="1">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Costo de Adquisición</label>
                        <input type="number" class="form-control" placeholder="₡0" min="0">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea class="form-control" rows="3" placeholder="Detalles adicionales del equipo..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal: Registrar Mantenimiento -->
<div class="modal fade" id="modalMantenimiento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Registrar Mantenimiento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tipo de Mantenimiento</label>
                        <select class="form-select">
                            <option>Seleccione tipo</option>
                            <option>Preventivo</option>
                            <option>Correctivo</option>
                            <option>Revision</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Fecha de Mantenimiento</label>
                        <input type="date" class="form-control">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Costo</label>
                        <input type="number" class="form-control" placeholder="₡0" min="0">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Observaciones</label>
                        <textarea class="form-control" rows="3" placeholder="Detalles del mantenimiento realizado..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-primary">Guardar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.js"></script>
