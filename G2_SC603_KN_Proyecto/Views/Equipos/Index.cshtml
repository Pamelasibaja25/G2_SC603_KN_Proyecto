@model List<G2_SC603_KN_Proyecto.Models.Equipo>

@{
    Layout = "_Layout";
}

<div id="page-inventory" class="section-page active p-6 lg:p-8">

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">

        <div>
            <h2 class="font-headline text-3xl font-bold tracking-tight">
                Inventario y Equipos
            </h2>

            <p class="text-on-surface-variant text-xs mt-1">
                Listado completo de equipos
            </p>
        </div>

        <form method="get" class="flex gap-3 flex-wrap">

            <div class="relative">

                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">
                    search
                </span>

                <input type="text"
                       name="buscar"
                       placeholder="Buscar equipo..."
                       class="input-field pl-9 py-2.5 text-sm w-52" />

            </div>

            <button type="submit" class="btn-primary py-2.5 text-sm">
                Buscar
            </button>

        </form>

    </div>

    <div class="bg-surface-container rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.3)]">

        <div class="overflow-x-auto">

            <table class="data-table">

                <thead>
                    <tr>
                        <th>Equipo</th>
                        <th>Categoría</th>
                        <th>Cantidad Disponible</th>
                        <th>Estado</th>
                        <th>Fecha Compra</th>
                        <th>Costo</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var equipo in Model)
                    {
                        <tr>
                            <td>@equipo.nombre</td>

                            <td>Equipamiento</td>

                            <td>1</td>

                            <td>@equipo.estado</td>

                            <td>
                                @equipo.fecha_compra
                            </td>

                            <td>
                                ₡@equipo.costo
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>