@model IEnumerable<G2_SC603_KN_Proyecto.Models.ClienteResumen>
@{
    Layout = "_Layout";
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="toast show" style="background:#201f1f; color:#4ade80;">
        <span class="material-symbols-outlined">check_circle</span>
        <span>@TempData["SuccessMessage"]</span>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="toast show" style="background:#201f1f; color:#ffb4ab;">
        <span class="material-symbols-outlined">error</span>
        <span>@TempData["ErrorMessage"]</span>
    </div>
}

<div id="page-clients" class="section-page active p-6 lg:p-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h2 class="font-headline text-3xl font-bold tracking-tight">Gestión de Clientes</h2>
            <p class="text-on-surface-variant text-xs mt-1">RMGM-01-001 al RMGM-01-014</p>
        </div>
        <div class="flex gap-3 flex-wrap">
            <div class="relative">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
                <input type="text" id="clientSearch" placeholder="Buscar cliente..." class="input-field pl-9 py-2.5 text-sm w-56" oninput="filterClients()" />
            </div>
            <select class="input-field py-2.5 text-sm w-40" id="clientStatusFilter" onchange="filterClients()">
                <option value="">Todos los estados</option>
                <option value="Activa">Activa</option>
                <option value="Vencida">Vencida</option>
                <option value="Suspendida">Suspendida</option>
            </select>
            <button class="btn-primary py-2.5 text-sm" onclick="openClientModal()">
                <span class="material-symbols-outlined text-[18px]">add</span> Nuevo Cliente
            </button>
        </div>
    </div>

    <div class="bg-surface-container rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(0,0,0,0.3)]">
        <div class="overflow-x-auto max-h-[400px] overflow-y-auto">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Cliente</th>
                        <th>Cédula</th>
                        <th>Teléfono</th>
                        <th>Correo</th>
                        <th>Fecha Nacimiento</th>
                        <th>Estado</th>
                        <th class="text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody id="clientsTableBody">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var cliente in Model)
                        {
                            <tr>
                                <td>@cliente.Nombre</td>
                                <td>@cliente.Cedula</td>
                                <td>@cliente.Telefono</td>
                                <td>@cliente.Correo</td>
                                <td>@cliente.fecha_nacimiento?.ToString("dd/MM/yyyy")</td>
                                <td>@cliente.Estado</td>
                                <td class="text-right">
                                    <a asp-action="Editar" asp-route-id="@cliente.id_cliente" class="btn-secondary">Editar</a>
                                    <a href="javascript:void(0)"
                                       class="btn-primary"
                                       onclick="openDetailsModal(this)"
                                       data-nombre="@cliente.Nombre"
                                       data-cedula="@cliente.Cedula"
                                       data-telefono="@cliente.Telefono"
                                       data-correo="@cliente.Correo"
                                       data-fecha="@cliente.fecha_nacimiento?.ToString("dd/MM/yyyy")"
                                       data-estado="@cliente.Estado"
                                       data-membresia="@cliente.EstadoMembresia"
                                       data-vencimiento="@cliente.Vencimiento?.ToString("dd/MM/yyyy")">
                                        Ver
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-outline">
                                No hay datos disponibles
                            </td>
                        </tr>
                    }
                </tbody>

            </table>
        </div>
        <div class="bg-surface-container-low px-6 py-4 flex items-center justify-between border-t border-outline-variant/10">
            <span class="text-xs text-outline" id="clientsCount">Mostrando todos los clientes</span>
        </div>
    </div>
</div>

<!-- MODAL VISUALIZAR INFO DETALLADA -->
<div class="modal-overlay" id="detailsModal">
    <div class="modal-box">
        <div class="flex items-center justify-between mb-6">
            <h3 class="font-headline font-bold text-xl">Detalles del Cliente</h3>
            <button onclick="closeModal('detailsModal')" class="btn-icon">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
                <label class="label-float">Nombre Completo</label>
                <input type="text" id="detalleNombre" class="input-field" readonly />
            </div>
            <div>
                <label class="label-float">Cédula</label>
                <input type="text" id="detalleCedula" class="input-field" readonly />
            </div>
            <div>
                <label class="label-float">Teléfono</label>
                <input type="text" id="detalleTelefono" class="input-field" readonly />
            </div>
            <div class="col-span-2">
                <label class="label-float">Correo Electrónico</label>
                <input type="email" id="detalleCorreo" class="input-field" readonly />
            </div>
            <div>
                <label class="label-float">Fecha Nacimiento</label>
                <input type="text" id="detalleFecha" class="input-field" readonly />
            </div>
            <div>
                <label class="label-float">Estado</label>
                <input type="text" id="detalleEstado" class="input-field" readonly />
            </div>
            <div class="grid grid-cols-2 gap-4 col-span-2">
                <div>
                    <label class="label-float">Estado Membresía</label>
                    <input type="text" id="detalleMembresia" class="input-field" readonly />
                </div>
                <div>
                    <label class="label-float">Vencimiento</label>
                    <input type="text" id="detalleVencimiento" class="input-field" readonly />
                </div>
            </div>

        </div>
    </div>
</div>

<!-- MODAL AGREGAR INFO-->
<div class="modal-overlay" id="clientModal">
    <div class="modal-box">
        <div class="flex items-center justify-between mb-6">
            <h3 class="font-headline font-bold text-xl" id="clientModalTitle">Nuevo Cliente</h3>
            <button onclick="closeModal('clientModal')" class="btn-icon"><span class="material-symbols-outlined">close</span></button>
        </div>
        <form asp-action="AgregarCliente" method="post" id="clientForm" class="space-y-4">
            <input type="hidden" id="clientId" />
            <div class="grid grid-cols-2 gap-4">
                <div class="col-span-2">
                    <label class="label-float">Nombre Completo *</label>
                    <input type="text" name="Nombre" class="input-field" placeholder="Ej: María González Solís" required />
                </div>
                <div>
                    <label class="label-float">Cédula / Identificación *</label>
                    <input type="text" name="Cedula" class="input-field" placeholder="XXXXXXXXX" required />
                </div>
                <div>
                    <label class="label-float">Teléfono *</label>
                    <input type="tel" name="Telefono" class="input-field" placeholder="8888-8888" required />
                </div>
                <div class="col-span-2">
                    <label class="label-float">Correo Electrónico *</label>
                    <input type="email" name="Correo" class="input-field" placeholder="correo@ejemplo.com" required />
                </div>
                <div>
                    <label class="label-float">Fecha de Nacimiento</label>
                    <input type="date" name="fecha_nacimiento" class="input-field" required />
                </div>
                <div>
                    <label class="label-float">Estado</label>
                    <select id="clientStatus" name="Estado" class="input-field">
                        <option value="Activa">Activa</option>
                        <option value="Vencida">Vencida</option>
                        <option value="Suspendida">Suspendida</option>
                    </select>
                </div>
            </div>
            <div class="flex gap-3 pt-2 justify-end">
                <button type="button" class="btn-secondary" onclick="closeModal('clientModal')">Cancelar</button>
                <button type="submit" class="btn-primary">
                    <span class="material-symbols-outlined text-[16px]">save</span> Guardar
                </button>
            </div>
        </form>
    </div>
</div>