@{
    Layout = "_Layout";
}
<div id="page-notifications" class="section-page active p-6 lg:p-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h2 class="font-headline text-3xl font-bold tracking-tight">Notificaciones</h2>
            <p class="text-on-surface-variant text-xs mt-1">RMGM-03-001 al RMGM-03-004</p>
        </div>
        <button class="btn-secondary py-2 text-sm" onclick="markAllNotificationsRead()">
            <span class="material-symbols-outlined text-[16px]">done_all</span> Marcar todas como leídas
        </button>
    </div>
    <div class="max-w-3xl space-y-3" id="notificationsList"></div>
</div>