@{
    Layout = "_Layout";
}

<div id="page-dashboard" class="section-page active p-6 lg:p-8 space-y-6">

    <!-- HEADER -->
    <div class="text-center mb-6">
        <h1 class="text-3xl font-bold tracking-tight">
            Bienvenido a Orion Fit
        </h1>
        <p class="text-on-surface-variant text-xs uppercase tracking-[0.15em] mt-1">
            Estado de su membresía
        </p>
    </div>

    <!-- ESTADO MEMBRESÍA -->
    <div class="flex items-center justify-center min-h-[50vh]">

        @if (ViewBag.MembresiaActiva != null)
        {
            <div id="membershipAlert"
                 class="bg-green-600/20 border border-green-500 text-green-200 px-10 py-8 rounded-2xl shadow-lg text-center w-full max-w-md">

                <div class="flex flex-col items-center gap-3">

                    <span class="material-symbols-outlined text-green-300 text-5xl">
                        verified
                    </span>

                    <h2 class="text-2xl font-bold">
                        Membresía activa
                    </h2>

                    <p class="text-sm text-green-100/80">
                        Su acceso al sistema está habilitado.
                    </p>

                    

                </div>
            </div>
        }
        else
        {
            <div id="membershipAlert"
                 class="bg-red-600/20 border border-red-500 text-red-200 px-10 py-8 rounded-2xl shadow-lg text-center w-full max-w-md">

                <div class="flex flex-col items-center gap-3">

                    <span class="material-symbols-outlined text-red-300 text-5xl">
                        cancel
                    </span>

                    <h2 class="text-2xl font-bold">
                        Membresía inactiva
                    </h2>

                    <p class="text-sm text-red-100/80">
                        Su acceso al sistema está restringido.
                    </p>

                  

                </div>
            </div>
        }

    </div>

</div>